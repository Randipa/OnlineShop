# Copy to .env before running: cp .env.example .env

JWT_SECRET=change-this-to-a-long-random-secret-min-32-chars

# Stripe (card payments)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret
# Must match STRIPE_SECRET_KEY account — https://dashboard.stripe.com/test/apikeys
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# PayHere (Sri Lanka — sandbox: https://sandbox.payhere.lk)
PAYHERE_MERCHANT_ID=your_merchant_id
PAYHERE_MERCHANT_SECRET=your_merchant_secret
PAYHERE_CURRENCY=LKR
PAYHERE_USD_TO_LKR_RATE=320
PAYHERE_SANDBOX=true

# Public backend URL for PayHere webhooks (use ngrok in local dev)
BACKEND_PUBLIC_URL=http://localhost:4000

# First-time setup: creates admin on container start
SEED_ON_START=true
ADMIN_EMAIL=admin@yourstore.com
ADMIN_PASSWORD=ChangeThisPassword123
ADMIN_NAME=Store Admin

# Cloudinary image bucket
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
