DATABASE_URL=postgresql://ecommerce:ecommerce_secret@localhost:5433/ecommerce
JWT_SECRET=generate-a-long-random-secret-min-32-chars
FRONTEND_URL=http://localhost:3000
PORT=4000
BACKEND_PUBLIC_URL=http://localhost:4000

# Stripe — https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# PayHere — https://sandbox.payhere.lk
PAYHERE_MERCHANT_ID=your_merchant_id
PAYHERE_MERCHANT_SECRET=your_merchant_secret
PAYHERE_CURRENCY=LKR
PAYHERE_USD_TO_LKR_RATE=320
PAYHERE_SANDBOX=true

# Initial admin (used only when running: npm run prisma:seed)
ADMIN_EMAIL=admin@yourstore.com
ADMIN_PASSWORD=change-this-strong-password
ADMIN_NAME=Store Admin

# Cloudinary image storage
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
